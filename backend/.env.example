# Google AI Studio Configuration
# Get your API key from: https://aistudio.google.com/api-keys
GOOGLE_API_KEY=your_google_api_key_here

# MongoDB Configuration
# Example: mongodb://localhost:27017/lanchain
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/lanchain
MONGODB_URI=mongodb://localhost:27017/lanchain

# Server Configuration
PORT=5000
NODE_ENV=development

# Application
APP_NAME=LanChain Backend
APP_VERSION=1.0.0
