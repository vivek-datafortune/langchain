# Groq AI Configuration (14,400 req/day free tier)
# Get your free API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# MongoDB Configuration
# Local: mongodb://localhost:27017/medivoice
# Docker: mongodb://mongodb:27017/medivoice
MONGODB_URI=mongodb://localhost:27017/medivoice

# Server Configuration
PORT=5001
NODE_ENV=development

# CORS: comma-separated allowed origins (default allows http/https localhost:5173, etc.)
# CLIENT_URL=https://localhost:5173

# HTTPS: set to 1 when UI is served over HTTPS (Vite with .cert) so API uses same protocol
# Copy client/.cert/key.pem and cert.pem to node-service/.cert, then:
# NODE_HTTPS=1
# In client set VITE_API_URL=https://localhost:5001/api
# SSL_KEY_PATH=/path/to/key.pem
# SSL_CERT_PATH=/path/to/cert.pem

# Whisper STT Service
# Local: http://localhost:8000
# Docker: http://whisper:8000
WHISPER_SERVICE_URL=http://localhost:8000

# JWT (phone-only auth)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Application
APP_NAME=MediVoice Backend
APP_VERSION=1.0.0
