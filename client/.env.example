# Backend API base URL (must include /api).
# Use HTTPS when the UI runs on HTTPS (Vite dev server with .cert) to avoid mixed content.
#
# ERR_CONNECTION_REFUSED? Start the backend:
#   Local: cd node-service && npm run dev
#   Docker: docker compose up -d   (API exposed on host port 5001)
#
# HTTP (default; matches local Node and Docker):
# VITE_API_URL=http://localhost:5001/api
#
# HTTPS (when UI is https://localhost:5173 and backend runs with NODE_HTTPS=1):
# VITE_API_URL=https://localhost:5001/api
